NODE_ENV=production
PORT=3000

# Email Configuration (usar seu próprio serviço de email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-senha-app
SMTP_FROM=contato@branquelas.com

# Destination email (onde receber as mensagens de contato)
CONTACT_EMAIL=seu-email@gmail.com

# Rate limiting (requisições por minuto)
RATE_LIMIT_MINUTES=15
RATE_LIMIT_MAX_REQUESTS=5

# CORS - Atualize com seu domínio da Vercel
CORS_ORIGIN=https://seu-projeto.vercel.app

# Security
SESSION_SECRET=seu-secret-aleatorio-aqui
